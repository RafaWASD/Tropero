# .env.example — plantilla de variables de entorno de RAFAQ.
#
# Copiá este archivo a `.env.local` (raíz del repo) y completá los valores reales.
# `.env.local` NO se commitea (.gitignore lo excluye). El cliente Expo (app/) lee las
# vars EXPO_PUBLIC_* desde el dir del proyecto: copiá las EXPO_PUBLIC_* también a
# `app/.env.local`.

# ----- Cliente (Expo bundle) — PÚBLICO, RLS / sync streams protegen los datos -----
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Endpoint de la instancia PowerSync Cloud (rafaq-beta, región BR). Lo provee el
# provisioning (ver spec 15, R1.1). Sin esta var, getEnv() falla con un error accionable.
EXPO_PUBLIC_POWERSYNC_URL=https://<instance-id>.powersync.journeyapps.com

# ----- Server-only (Edge Functions, CLI). NUNCA exponer al cliente -----
# Bypassea RLS. Rotar antes de producción.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_PROJECT_REF=<project-ref>

# Para que `supabase` CLI / la Management API no requieran login interactivo.
SUPABASE_ACCESS_TOKEN=<personal-access-token>

# Para que Edge Functions puedan enviar push notifications via Expo Push API.
EXPO_ACCESS_TOKEN=<expo-access-token>

RESEND_API_KEY=<resend-key>
FIGMA_API_KEY=<figma-key>
STITCH_API_KEY=<stitch-key>
