# app/.env.example — variables que el cliente Expo (app/) necesita para dev / build / e2e.
#
# Copiá este archivo a `app/.env.local` y completá los valores reales.
# `app/.env.local` NO se commitea (.gitignore lo excluye).
#
# El bundle de Expo —incluido `expo export -p web` que sirve los e2e de Playwright— lee
# estas EXPO_PUBLIC_* desde el dir del proyecto (app/). Son PÚBLICAS (van al bundle del
# cliente); la RLS + las sync streams protegen los datos.
#
# ⚠️ Sin EXPO_PUBLIC_POWERSYNC_URL acá, el boot tira "Faltan variables de entorno
#    EXPO_PUBLIC_*" y las pantallas con PowerSync quedan EN BLANCO (los e2e de PowerSync
#    fallan con "element(s) not found" en el login). Tiene que estar en app/.env.local,
#    no solo en el .env.local de la raíz (que es el que leen los tests node).
#
# Las vars server-only (SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ACCESS_TOKEN, RESEND_API_KEY,
# etc.) NO van acá — van en el .env.local de la RAÍZ del repo. Ver ../.env.example.

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Endpoint de la instancia PowerSync Cloud (rafaq-beta, región BR; spec 15 R1.1).
EXPO_PUBLIC_POWERSYNC_URL=https://<instance-id>.powersync.journeyapps.com
