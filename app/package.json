{
  "name": "rafaq-app",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "copy-powersync-assets": "powersync-web copy-assets --output public",
    "web": "pnpm run copy-powersync-assets && expo start --web",
    "typecheck": "tsc --noEmit",
    "e2e:build": "pnpm run copy-powersync-assets && expo export -p web",
    "e2e:test": "playwright test",
    "e2e": "pnpm run e2e:build && playwright test",
    "e2e:report": "pnpm run e2e:build && playwright test --config playwright.report.config.ts"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@journeyapps/wa-sqlite": "1.7.0",
    "@powersync/react": "1.10.0",
    "@powersync/react-native": "1.35.3",
    "@powersync/web": "1.38.2",
    "@react-navigation/bottom-tabs": "7.16.2",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "@supabase/supabase-js": "^2.106.1",
    "@tamagui/config": "2.0.0",
    "@tamagui/core": "2.0.0",
    "expo": "~56.0.4",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "^56.0.15",
    "expo-device": "^56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-linear-gradient": "^56.0.4",
    "expo-linking": "^56.0.11",
    "expo-notifications": "^56.0.13",
    "expo-router": "~56.2.7",
    "expo-secure-store": "^56.0.4",
    "expo-sharing": "~56.0.16",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "lucide-react-native": "1.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "tamagui": "2.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tamagui/babel-plugin": "2.0.0",
    "@tamagui/metro-plugin": "2.0.0",
    "@types/react": "~19.2.2",
    "serve": "^14.2.6",
    "supabase": "^2.101.0",
    "typescript": "~6.0.3",
    "ws": "^8.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "expo",
      "expo-modules-core",
      "@expo/cli",
      "esbuild",
      "supabase",
      "@journeyapps/wa-sqlite"
    ],
    "overrides": {
      "react-dom": "19.2.3"
    }
  }
}
