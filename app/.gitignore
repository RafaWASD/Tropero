# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
dist-check/
web-build/
expo-env.d.ts

# Tamagui (build cache del optimizing compiler)
.tamagui/

# PowerSync web — assets de runtime (worker UMD + wa-sqlite WASM) servidos desde public/.
# Build-artifact: los regenera el prebuild `copy-powersync-assets` (script `web`/`e2e:build`,
# = `powersync-web copy-assets --output public`). NO se commitean (binarios pesados, versionados
# con el SDK). Un clone fresco los obtiene al correr `pnpm web`. Ver impl_15 Hotfix Run 1.2.
public/@powersync/

# Playwright E2E (artefactos de corrida — NO se commitean)
test-results/
playwright-report/
blob-report/
.playwright/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# CDP headless capture (throwaway perfiles de Edge para verificación visual de render)
.cdp-profile*/
dist_tmp/

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
