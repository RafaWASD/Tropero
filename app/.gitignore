# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
dist-check/
web-build/
expo-env.d.ts

# Tamagui (build cache del optimizing compiler)
.tamagui/

# Playwright E2E (artefactos de corrida — NO se commitean)
test-results/
playwright-report/
blob-report/
.playwright/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# CDP headless capture (throwaway perfiles de Edge para verificación visual de render)
.cdp-profile*/
dist_tmp/

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
