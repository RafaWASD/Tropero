# pnpm config — RAFAQ app

# CRITICAL para Expo / React Native: Metro (el bundler) no maneja bien los
# symlinks que pnpm usa por default. node-linker=hoisted le dice a pnpm que
# genere un node_modules tradicional plano (como npm) pero manteniendo el
# resto de las ventajas de pnpm (store content-addressable, lockfile estricto,
# onlyBuiltDependencies).
# Ref: https://docs.expo.dev/guides/monorepos/ y issues conocidos de Metro.
node-linker=hoisted

# Modo estricto para postinstall scripts: por default NO se ejecutan scripts
# de paquetes ajenos. Hay que whitelistear explícitamente en
# package.json -> pnpm.onlyBuiltDependencies. Defensa principal contra ataques
# tipo shai-hulud / postinstall-malware. Ver ADR-011.
# Nota: pnpm 10+ ya tiene este comportamiento por default, pero lo explicitamos.
side-effects-cache=true
