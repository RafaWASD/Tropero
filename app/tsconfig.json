{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "**/*.test.ts",
    "**/*.test.tsx",
    "e2e",
    "playwright.config.ts",
    "playwright.report.config.ts",
    "playwright.capture.config.ts"
  ]
}
