{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check.mjs",
            "description": "Antes de cerrar sesion, validar el harness completo."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(node scripts/check.mjs)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(npx expo *)",
      "Bash(supabase *)"
    ]
  }
}
